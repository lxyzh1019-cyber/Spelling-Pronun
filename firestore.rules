rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users document — only accessible by the user themselves
    match /spelling-users/{userId} {
      allow read, write: if request.auth.uid == userId;

      match /{document=**} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // Progress documents — per-user and per-profile isolation
    // Document ID format: {userId}_{profileId}_{wordId}
    match /spelling-progress/{document=**} {
      allow read: if
        request.auth.uid != null &&
        request.auth.uid == resource.data.userId;

      allow create: if
        request.auth.uid != null &&
        request.auth.uid == request.resource.data.userId;

      allow update: if
        request.auth.uid != null &&
        request.auth.uid == resource.data.userId &&
        request.auth.uid == request.resource.data.userId;

      allow delete: if
        request.auth.uid != null &&
        request.auth.uid == resource.data.userId;
    }

    // Achievements — per-user/profile
    match /spelling-achievements/{document} {
      allow read, write: if
        request.auth.uid != null &&
        document.matches(request.auth.uid + '_.*');
    }

    // Hints tracker — per-user/profile
    match /spelling-hints/{document} {
      allow read, write: if
        request.auth.uid != null &&
        document.matches(request.auth.uid + '_.*');
    }

    // Daily challenge — per-user/profile
    match /spelling-daily-challenges/{document} {
      allow read, write: if
        request.auth.uid != null &&
        document.matches(request.auth.uid + '_.*');
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
